// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Shipment {
  id          String   @id
  origin      String
  destination String
  status      String
  eta         DateTime
  carrier     String
  latitude    Float?
  longitude   Float?
}

model User {
  id    String @id
  email String @unique
  role  String
  plan  String
}

model Document {
  id          String @id
  shipmentId  String
  type        String
  status      String
}