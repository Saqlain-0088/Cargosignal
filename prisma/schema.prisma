generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  password    String?   // null for OAuth users
  provider    String    @default("email") // email | google | magic_link
  role        String    @default("viewer")
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     CompanyTenant? @relation(fields: [companyId], references: [id])
  shipments   UserShipment[]
}

model CompanyTenant {
  id              String   @id @default(cuid())
  name            String
  industry        String
  status          String   @default("active")
  activeShipments Int      @default(0)
  totalSpend      Float    @default(0)
  userCount       Int      @default(0)
  joinDate        DateTime @default(now())
  logo            String?

  users           User[]
}

model Shipment {
  id          String   @id @default(cuid())
  origin      String
  destination String
  status      String
  eta         DateTime
  carrier     String
  cargoType   String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  containers     Container[]
  customsEvents  CustomsEvent[]
  logisticsCosts LogisticsCost[]
  userShipments  UserShipment[]
}

// Junction: which users are tracking which shipments
model UserShipment {
  id         String   @id @default(cuid())
  userId     String
  shipmentId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([userId, shipmentId])
}

model Container {
  id              String @id @default(cuid())
  shipmentId      String
  containerNumber String
  size            String
  type            String
  currentLocation String
  temperature     Float?
  humidity        Float?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model Alert {
  id        String   @id @default(cuid())
  type      String
  severity  String
  message   String
  timestamp DateTime @default(now())
  relatedId String?
}

model Port {
  id        String @id @default(cuid())
  name      String
  code      String
  country   String
  latitude  Float
  longitude Float
}

model CustomsEvent {
  id         String   @id @default(cuid())
  shipmentId String
  event      String
  status     String
  timestamp  DateTime @default(now())
  location   String
  notes      String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model LogisticsCost {
  id         String   @id @default(cuid())
  shipmentId String
  category   String
  amount     Float
  currency   String
  status     String
  date       DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model Document {
  id         String @id @default(cuid())
  shipmentId String
  type       String
  status     String
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#3b82f6")
  permissions String[]

  members AdminMember[]
}

model AdminMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  roleId    String
  status    String   @default("active")
  joinedAt  DateTime @default(now())

  role AdminRole @relation(fields: [roleId], references: [id])
}
